# ════════════════════════════════════════════════════════════════
# glossary .env 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
# .env 는 .gitignore 에 의해 git에 포함되지 않습니다
# ════════════════════════════════════════════════════════════════

# ── API 설정 ─────────────────────────────────────────────────────
# 사용할 API 종류: claude | openai | google
API_KEY_TYPE=google

ANTHROPIC_API_KEY=sk-ant-여기에입력
GOOGLE_API_KEY=AIzaSyDa7zpllPlVBQtfX1nKGyrV5nprS88l1dY
OPENAI_API_KEY=여기에입력

# ── 프로젝트 경로 ────────────────────────────────────────────────
# 비워두면 glossary/ 의 상위 폴더를 자동 감지
# Windows 예시: E:\project\ts1
# Mac/Linux 예시: /home/user/projects/BomTS
PROJ_ROOT=E:\project\glossary

# ── 스캔 제외 설정 ───────────────────────────────────────────────
# 완전 제외 (내용도 안 봄, 폴더명도 후보로 안 넣음)
EXCLUDE_DIRS=backup,data,tests,tmp,glossary,.git,__pycache__,node_modules,.venv,venv

# 내용은 안 보고 파일명만 후보로 사용하는 폴더
EXCLUDE_FILE_CONTENT=cache,doc,logs

# 내용 스캔 제외 확장자
EXCLUDE_EXTENSIONS=.md,.txt,.log,.csv,.png,.jpg,.jpeg,.pdf,.ico,.svg

# ── 배치 설정 ────────────────────────────────────────────────────
# 한 번에 API에 넘길 용어 후보 수 (너무 크면 토큰 폭발 주의)
BATCH_CHUNK_SIZE=300

# API 응답 최대 토큰
MAX_OUTPUT_TOKENS=4000

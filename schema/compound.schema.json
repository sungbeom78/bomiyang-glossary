{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Compound",
  "type": "object",
  "required": [
    "id",
    "words",
    "lang",
    "domain",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(\\[N\\])?[a-z][a-z0-9_]*(\\[N\\])?[a-z0-9_]*$|^[a-z][a-z0-9_]*(\\[N\\])[a-z0-9_]*$"
    },
    "words": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "domain": {
      "type": "string",
      "enum": [
        "trading",
        "market",
        "system",
        "infra",
        "ui",
        "general",
        "proper"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated"
      ]
    },
    "lang": {
      "type": "object",
      "properties": {
        "en": {
          "type": "string"
        },
        "ko": {
          "type": "string"
        },
        "ja": {
          "type": "string"
        },
        "zh_hans": {
          "type": "string"
        }
      },
      "required": [
        "en"
      ]
    },
    "abbr": {
      "type": "object",
      "properties": {
        "long": {
          "type": "string"
        },
        "short": {
          "type": "string"
        }
      }
    },
    "variants": {
      "type": "object",
      "properties": {
        "plural": {
          "type": "string"
        },
        "verb": {
          "type": "string"
        },
        "past": {
          "type": "string"
        },
        "past_participle": {
          "type": "string"
        },
        "present_participle": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        },
        "abbreviation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adjective": {
          "type": "string"
        },
        "adverb": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "misspelling": {
          "type": "string"
        },
        "singular": {
          "type": "string"
        },
        "noun_form": {
          "type": "string"
        },
        "verb_form": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "description_i18n": {
      "type": "object",
      "properties": {
        "ko": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "not": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}

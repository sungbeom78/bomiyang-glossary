{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Banned",
  "type": "object",
  "required": ["expression", "reason", "severity"],
  "properties": {
    "expression": {"type": "string"},
    "lang": {"type": "string"},
    "correct": {"type": "string"},
    "reason_i18n": {
      "type": "object",
      "properties": {
        "ko": {"type": "string"},
        "en": {"type": "string"}
      }
    },
    "reason": {"type": "string"},
    "severity": {
      "type": "string",
      "enum": ["warn", "error"]
    }
  },
  "additionalProperties": false
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Word",
  "description": "BOM_TS 단어 사전 항목 — Plan v2.5.1 §3.3",
  "type": "object",
  "required": [
    "id",
    "domain",
    "status",
    "canonical_pos",
    "lang",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*$"
    },
    "domain": {
      "anyOf": [
        { "type": "string", "enum": ["trading", "market", "system", "infra", "ui", "general", "proper"] },
        { "type": "array", "items": { "type": "string", "enum": ["trading", "market", "system", "infra", "ui", "general", "proper"] } }
      ]
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated"],
      "default": "active"
    },
    "canonical_pos": {
      "type": "string",
      "enum": ["noun", "verb", "adj", "adv", "prefix", "suffix", "proper", "mixed"]
    },
    "lang": {
      "type": "object",
      "properties": {
        "en":      { "type": "string" },
        "ko":      { "type": "string" },
        "ja":      { "type": "string" },
        "zh_hans": { "type": "string" }
      },
      "required": ["en"]
    },
    "variants": {
      "description": "§3.2 지원 타입 전체 포함. §3.4 정렬: abbreviation > alias > plural > singular > 기타",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "plural", "singular", "abbreviation", "alias",
              "misspelling", "adjective", "adverb", "verb",
              "noun_form", "verb_form", "present_participle",
              "past", "past_participle", "agent", "pos_forms", "deprecated"
            ]
          },
          "types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "plural", "singular", "abbreviation", "alias",
                "misspelling", "adjective", "adverb", "verb",
                "noun_form", "verb_form", "present_participle",
                "past", "past_participle", "agent", "pos_forms", "deprecated"
              ]
            }
          },
          "value":  { "type": "string" },
          "short":  { "type": "string" },
          "long":   { "type": "string" },
          "domain": { "type": "string" },
          "noun":   { "type": "array", "items": { "type": "string" } },
          "verb":   { "type": "array", "items": { "type": "string" } },
          "adj":    { "type": "array", "items": { "type": "string" } },
          "adv":    { "type": "array", "items": { "type": "string" } },
          "abbreviation_meta": {
            "type": "object",
            "properties": {
              "confidence": { "enum": ["high", "medium", "low"] },
              "source":     { "enum": ["dictionary", "api", "ai", "manual"] },
              "ambiguity":  { "enum": ["low", "medium", "high"] }
            }
          }
        },
        "anyOf": [
          { "required": ["type"] },
          { "required": ["types"] }
        ],
        "oneOf": [
          { "required": ["value"] },
          { "required": ["short"] }
        ]
      }
    },
    "description_i18n": {
      "type": "object",
      "properties": {
        "ko": { "type": "string" },
        "en": { "type": "string" }
      }
    },
    "source_urls": {
      "type": "array",
      "items": { "type": "string" }
    },
    "from": {
      "type": "string"
    },
    "synonyms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "antonyms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "derived_terms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "not": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reason":       { "type": "string" },
    "note":         { "type": "string" },
    "abbreviation": {
      "description": "단어 단위 약어 메타데이터. 복합어 기반 약어는 compounds.json variants 사용.",
      "type": "object",
      "properties": {
        "short":          { "type": "string",  "description": "약어 표기 (예: auto)" },
        "long":           { "type": "string",  "description": "풀네임 word id (예: automatic)" },
        "case_sensitive": { "type": "boolean", "default": false },
        "confidence":     { "type": "string",  "enum": ["high", "medium", "low"] },
        "ambiguity":      { "type": "string",  "enum": ["low", "medium", "high"] }
      },
      "required": ["short"],
      "additionalProperties": false
    },
    "created_at":   { "type": "string", "format": "date-time" },
    "updated_at":   { "type": "string", "format": "date-time" },
    "deprecated_at":{ "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
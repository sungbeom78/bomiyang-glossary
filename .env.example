# ════════════════════════════════════════════════════════════════
# glossary .env 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
# .env 는 .gitignore 에 의해 git에 포함되지 않습니다
# ════════════════════════════════════════════════════════════════

# ── API 설정 ─────────────────────────────────────────────────────
# 사용할 API 종류: claude | openai | google
API_KEY_TYPE=claude

# 사용할 모델 (비워두면 API별 기본값 사용)
# claude : claude-sonnet-4-20250514 / claude-opus-4-6 / claude-haiku-4-5-20251001
# openai : gpt-4o / gpt-4o-mini / gpt-4-turbo
# google : gemini-2.0-flash / gemini-1.5-pro / gemini-1.5-flash
API_MODEL=

ANTHROPIC_API_KEY=sk-ant-여기에입력
GOOGLE_API_KEY=여기에입력
OPENAI_API_KEY=여기에입력

# ── 프로젝트 경로 ────────────────────────────────────────────────
# 비워두면 glossary/ 의 상위 폴더를 자동 감지
# Windows 예시: E:\project\antigravity
# Mac/Linux 예시: /home/user/projects/antigravity
PROJ_ROOT=

# ── 스캔 제외 설정 ───────────────────────────────────────────────
# 완전 제외 (내용도 안 봄, 폴더명도 후보로 안 넣음)
EXCLUDE_DIRS=backup,data,tests,lib_test,tmp,glossary,.git,__pycache__,node_modules,.venv,venv

# 내용은 안 보고 파일명만 후보로 사용하는 폴더
EXCLUDE_FILE_CONTENT=cache,doc,log

# 내용 스캔 제외 확장자
EXCLUDE_EXTENSIONS=.md,.txt,.log,.csv,.png,.jpg,.jpeg,.pdf,.ico,.svg

# ── 배치 설정 ────────────────────────────────────────────────────
# 한 번에 API에 넘길 용어 후보 수 (너무 크면 토큰 폭발 주의)
BATCH_CHUNK_SIZE=300

# API 응답 최대 토큰 (4000이면 JSON이 잘릴 수 있음 → 8192 권장)
MAX_OUTPUT_TOKENS=8192


## # 1. .env 생성
## cp .env.example .env
## # .env 열어서 API_KEY_TYPE, API키, PROJ_ROOT 입력
## 
## # 2. 서버 실행
## python glossary/web/server.py

## 1. 스캔 탭
##    → "▷ 스캔 실행"   : API 없이 후보 추출, 미리보기
##    → "▷ dry-run"     : 토큰 예상치 확인 (API 미호출)
##    → "▷ API 분석 실행" : 실제 분석 → tmp/terms/terms_날짜.json 생성
## 
## 2. 결과 파일 탭
##    → 생성된 파일 목록 확인
##    → "병합 →" 버튼으로 3번 탭 이동
## 
## 3. 병합 탭
##    → 추출된 용어 체크박스로 선택/해제
##    → "전체 병합" 또는 "선택 항목만 병합"
##    → terms.json 에 즉시 반영

## # 후보 수만 확인
## python glossary/bin/scan_terms.py --count
## 
## # 후보 목록 상세 보기
## python glossary/bin/scan_terms.py
## 
## # 토큰 예상치 확인 (API 미호출)
## python glossary/bin/batch_terms.py --dry-run
## 
## # 실제 실행
## python glossary/bin/batch_terms.py
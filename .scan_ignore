# .scan_ignore — 스캔 제외 폴더 및 파일 규칙
# 형식:
#   dir:<폴더명>       → 해당 이름의 폴더(하위 전체) 제외
#   ext:<확장자>       → 해당 확장자 파일 제외 (예: ext:.md)
#   pattern:<glob>     → 해당 glob 패턴과 일치하는 파일/폴더 제외
#
# 주의: 제외 규칙은 스캔 대상(.scan_list)보다 항상 우선 적용된다.

# 제외 폴더
dir:__pycache__

# 제외 파일 확장자
ext:.md

# 제외 파일 패턴 (glob 기반)
pattern:.git*

# 제외 폴더 (유저 요청: 테스트 방지)
dir:test
dir:tests

# ─── 로그 및 실행 결과 ─────────────────────────────────────
log/*
logs/*
data/*
tmp/*
cache/*
*.log

# ─── 디렉토리 유지용 파일은 포함 ────────────────────────────
!log/.gitkeep
!data/.gitkeep
!tmp/.gitkeep
!cache/.gitkeep

# ─── 환경 파일 및 민감 정보 ────────────────────────────────
.env
.env.*
*.env
!.env.example
!.env.linux_main.example
!.env.mt5_node.example

# ─── Config (운영 설정 — 서버별 상이, 민감정보 포함 가능) ──
config/settings.yaml
config/cookies/
*.token
*.pid

# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# ─── Plan ─────────────────────────────────────────────────
doc/plan/*_utf8.txt
doc/plan/*_text.txt

# ─── Backup ──────────────────────────────────────────────
backup/
backups/

# ─── Test ─────────────────────────────────────────────────
.pytest_cache/

# ─── DB ───────────────────────────────────────────────────
*.db
*.sqlite3
.omx/
.codex/
log/
